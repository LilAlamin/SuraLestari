let teamSwiper = null;
const TABLET_BREAKPOINT = 991;

function initTeamSwiper() {
  if (window.innerWidth <= TABLET_BREAKPOINT && !teamSwiper) {
    teamSwiper = new Swiper('.swiper.team', {
      speed: 500,
      slideToClickedSlide: true,
      slidesPerView: "auto",
      navigation: {
        nextEl: '.portfolio_arrow.team-next',
        prevEl: '.portfolio_arrow.team-prev',
        disabledClass: 'disabled',
      },
    });
  } else if (window.innerWidth > TABLET_BREAKPOINT && teamSwiper) {
    teamSwiper.destroy(true, true);
    teamSwiper = null;
  }
}

// Init on load
initTeamSwiper();

// Re-check on resize
window.addEventListener('resize', initTeamSwiper);
</script>


<!--------------------TEAM HOVER INTERACTION---------->
<script>
const slides = document.querySelectorAll('.swiper-slide.team');

slides.forEach(slide => {
  slide.addEventListener('mouseenter', () => {
    slides.forEach(s => {
      const img = s.querySelector('.team_portrait-img');
      if (img) img.style.opacity = s === slide ? '1' : '0.25';
    });
  });

  slide.addEventListener('mouseleave', () => {
    slides.forEach(s => {
      const img = s.querySelector('.team_portrait-img');
      if (img) img.style.opacity = '1';
    });
  });
});
</script>



<script>
"use strict"; // fix lenis in safari

if (Webflow.env("editor") === undefined) {
  const lenis = new Lenis({
    lerp: 0.08,
    wheelMultiplier: 1,
    infinite: false,
    gestureOrientation: "vertical",
    normalizeWheel: false,
    smoothTouch: false
  });

  function raf(time) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }
  requestAnimationFrame(raf);

  $("[data-lenis-start]").on("click", function () {
    lenis.start();
  });
  $("[data-lenis-stop]").on("click", function () {
    lenis.stop();
  });
  $("[data-lenis-toggle]").on("click", function () {
    $(this).toggleClass("stop-scroll");
    if ($(this).hasClass("stop-scroll")) {
      lenis.stop();
    } else {
      lenis.start();
    }
  });
}
</script>

<script type="text/javascript">
// Function to check screen size and load script if necessary
const loadScriptIfNecessary = () => {
  // Check if window width is below 768px
  if (window.innerWidth < 768) {
    // Create the script element
    var script = document.createElement('script');

    // Set the script's attributes
    script.async = true;
    script.src = "https://cdn.jsdelivr.net/npm/@finsweet/attributes-cmsslider@1/cmsslider.js";

    // Append the script to the head of the document
    document.head.appendChild(script);
  }
};

// Initial call to loadScriptIfNecessary
loadScriptIfNecessary();
</script>


<script>
// Get all elements with the class .mentor_cms-wrapper
const mentorWrappers = document.querySelectorAll('.mentor_cms-wrapper');
console.log(mentorWrappers);

let timeoutId;

// Function to pause all animations
function pauseAllAnimations() {
  // Clear any existing timeout to ensure the animation doesn't resume accidentally
  clearTimeout(timeoutId);

  for (const wrapper of mentorWrappers) {
    wrapper.style.animationPlayState = 'paused';
  }
}

// Function to resume all animations
function resumeAllAnimations() {
  timeoutId = setTimeout(() => {
    for (const wrapper of mentorWrappers) {
      wrapper.style.animationPlayState = 'running';
    }
  }, 200);
}

// Add hover event listeners to pause and resume animations
for (const wrapper of mentorWrappers) {
  wrapper.addEventListener('mouseenter', () => {
    // Clear any existing timeout when entering a new wrapper
    clearTimeout(timeoutId);
    pauseAllAnimations();
  });

  wrapper.addEventListener('mouseleave', () => {
    // Set a timeout to resume the animations
    timeoutId = setTimeout(resumeAllAnimations, 200);
  });
}
</script>


<script>
// Function to execute the change
const manipulateDOM = () => {
  // Only execute the function if the screen width is >= 768px
  if (window.innerWidth >= 768) {
    const portfolioList = document.querySelector('.portfolio_list');
    const portfolioCTA = document.querySelector('.portfolio_cta');

    if (portfolioList && portfolioCTA) {
      // Append portfolioCTA as the last child of portfolioList
      portfolioList.appendChild(portfolioCTA);
      portfolioCTA.style.display = "flex";
    }
  }
};

// Initial call to manipulateDOM
manipulateDOM();

// Add event listener for window resize
window.addEventListener('resize', () => {
  // Recheck the screen size and possibly execute the function
  manipulateDOM();
});

</script>

<script>
// Get the input element by its ID
const inputElement = document.querySelector(".form_input-footer");

// Save the original placeholder text
const originalPlaceholder = inputElement.placeholder;

// Add event listener for focus event
inputElement.addEventListener('focus', function() {
  // Hide the placeholder when focused
  this.placeholder = '';
});

// Add event listener for blur event
inputElement.addEventListener('blur', function() {
  // Show the original placeholder when blurred
  this.placeholder = originalPlaceholder;
});
</script>


